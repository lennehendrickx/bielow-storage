# Bie-low Storage - Jekyll for GitHub Pages
# GitHub Pages uses Jekyll 3.9.x; local can use 4.x if Ruby >= 3.0
source "https://rubygems.org"

gem "jekyll", "~> 3.9"
gem "webrick", "~> 1.8"

group :jekyll_plugins do
  gem "jekyll-sitemap"
end

platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo-data"
end
